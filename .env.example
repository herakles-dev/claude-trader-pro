# ============================================
# Claude Trader Pro - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- AI Providers ----
AI_PROVIDER=claude                          # claude or gemini
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ---- Database (PostgreSQL) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=trader
POSTGRES_PASSWORD=your-postgres-password-here
POSTGRES_DB=trader_db
DATABASE_URL=postgresql://trader:your-postgres-password-here@localhost:5432/trader_db

# ---- API Gateway (Node.js) ----
NODE_ENV=development
PORT=3001
JWT_SECRET=your-jwt-secret-here
CORS_ALLOWED_ORIGINS=http://localhost:3000
CLAUDE_ENGINE_URL=http://localhost:8000
CLAUDE_ENGINE_TIMEOUT=30000
CLAUDE_ENGINE_RETRIES=3
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# ---- WebSocket ----
WS_PING_INTERVAL=30000
WS_PING_TIMEOUT=10000
WS_BROADCAST_INTERVAL=5000
REACT_APP_WS_URL=ws://localhost:3001

# ---- Redis (optional) ----
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ---- External Data APIs ----
TAAPI_API_KEY=your-taapi-api-key-here
FRED_API_KEY=your-fred-api-key-here

# ---- Reddit API (sentiment analysis) ----
REDDIT_CLIENT_ID=your-reddit-client-id-here
REDDIT_CLIENT_SECRET=your-reddit-client-secret-here
REDDIT_USER_AGENT=claude-trader-pro/1.0

# ---- Prediction Engine ----
PREDICTION_ENABLED=true
PREDICTION_INTERVAL_MINUTES=60
PREDICTION_MAX_RETRIES=3
PREDICTION_RETRY_BASE_DELAY=5
DEFAULT_PREDICTION_SYMBOL=BTC/USDT
NEUTRAL_THRESHOLD_PCT=0.5
DAILY_BUDGET_LIMIT=1.00

# ---- Risk Management ----
RISK_INITIAL_PORTFOLIO=10000
RISK_MAX_POSITION_PCT=5.0
RISK_MIN_POSITION_PCT=1.0
RISK_MAX_DAILY_LOSS_PCT=3.0
RISK_MAX_DRAWDOWN_PCT=10.0
RISK_MAX_DAILY_TRADES=10
RISK_MAX_CONSEC_LOSSES=3
RISK_MIN_CONFIDENCE=0.6
RISK_HIGH_CONFIDENCE=0.8
RISK_COOLDOWN_HOURS=4
RISK_VOLATILITY_THRESHOLD=2.0
RISK_VOLATILITY_REDUCTION=0.5
RISK_DRAWDOWN_REDUCE_PCT=50.0

# ---- Trade Execution ----
AUTO_EXECUTE_ENABLED=false
EXECUTION_CONFIDENCE_THRESHOLD=0.75
EXECUTION_MAX_ORDER_VALUE=500
EXECUTION_POSITION_SIZE_PCT=2.0
TRADE_TRACKING_ENABLED=true
TRADE_POLL_INTERVAL=60

# ---- Backtesting ----
BACKTEST_DEFAULT_DAYS=30
BACKTEST_STARTING_CAPITAL=10000
BACKTEST_POSITION_SIZE_PCT=2.0
BACKTEST_CONFIDENCE_THRESHOLD=0.65

# ---- Evaluation ----
EVALUATION_ENABLED=true
EVALUATION_INTERVAL_MINUTES=30
EVALUATION_DELAY_HOURS=4
EVALUATION_BATCH_SIZE=50

# ---- OctoBot Integration ----
OCTOBOT_URL=http://localhost:5001
OCTOBOT_WEBHOOK_TOKEN=your-octobot-webhook-token-here
OCTOBOT_SYNC_ENABLED=false
OCTOBOT_SYNC_INTERVAL=60
OCTOBOT_TIMEOUT=10

# ---- Monitoring ----
LOKI_URL=http://localhost:3100
